{
  "id": "net.xmind.XMind",
  "command": "xmind",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "base": "org.electronjs.Electron2.BaseApp",
  "base-version": "25.08",
  "separate-locales": false,
  "rename-icon": "xmind",
  "rename-mime-file": "xmind.xml",
  "finish-args": [
    "--socket=wayland",
    "--socket=fallback-x11",
    "--share=ipc",
    "--device=dri",
    "--socket=pulseaudio",
    "--share=network",
    "--filesystem=xdg-download",
    "--filesystem=xdg-documents",
    "--filesystem=xdg-pictures",
    "--filesystem=xdg-desktop",
    "--filesystem=/tmp",
    "--talk-name=org.freedesktop.Notifications",
    "--filesystem=/run/media",
    "--filesystem=/media",
    "--filesystem=home"
  ],
  "modules": [
    {
      "name": "xmind",
      "buildsystem": "simple",
      "build_commands": [
        "ar x xmind.deb",
        "tar xf data.tar.gz",
        "cp -r usr/* /app",
        "mkdir -p /app/main",
        "cp -r opt/Xmind/* /app/main",
        "install -Dm644 net.xmind.XMind.metainfo.xml /app/share/metainfo/net.xmind.XMind.metainfo.xml",
        "install -Dm644 net.xmind.XMind.desktop -t /app/share/applications",
        "mkdir -p /app/bin",
        "install -Dm755 xmind /app/bin/xmind",
        "rm -rf /app/share/icons/hicolor/1024x1024"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://xmind.app/xmind/downloads/Xmind-for-Linux-amd64bit-26.02.04171-202602092329.deb",
          "sha256": "4e18a6d6caf728f7def847e6a59ee1f41b6d2f862411ee6e4b43d791997c8404",
          "dest-filename": "xmind.deb",
          "only-arches": ["x86_64"]
        },
        {
          "type": "file",
          "url": "https://xmind.app/xmind/downloads/Xmind-for-Linux-arm64bit-26.02.04172-202604121808.deb",
          "sha256": "f531c0806b935148f17a8ec5e36f2d8e2464bac992337026062ec077ddeaab40",
          "dest-filename": "xmind.deb",
          "only-arches": ["aarch64"]
        },
        {
          "type": "file",
          "path": "net.xmind.XMind.metainfo.xml"
        },
        {
          "type": "file",
          "path": "net.xmind.XMind.desktop"
        },
        {
          "type": "script",
          "dest-filename": "xmind",
          "commands": [
            "export TMPDIR=\"$XDG_RUNTIME_DIR/app/$FLATPAK_ID\"",
            "exec zypak-wrapper /app/main/xmind --ozone-platform-hint=auto \"$@\""
          ]
        }
      ]
    }
  ]
}
